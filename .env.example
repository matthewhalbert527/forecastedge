# Shared
NODE_ENV=development
APP_MODE=paper
API_PORT=4000
WEB_PUBLIC_API_URL=http://localhost:4000
RUN_BACKGROUND_WORKER=false
RUN_ON_STARTUP=true
BACKGROUND_POLL_INTERVAL_MINUTES=30
FORECAST_CACHE_MINUTES=45
OPEN_METEO_COOLDOWN_MINUTES=60

# Weather
DEFAULT_POLL_INTERVAL_MINUTES=30
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
NWS_BASE_URL=https://api.weather.gov
NWS_USER_AGENT=ForecastEdge/0.1 contact@example.com
ACCUWEATHER_BASE_URL=https://dataservice.accuweather.com
ACCUWEATHER_API_KEY=
NOAA_CDO_TOKEN=

# Kalshi public market data
KALSHI_PROD_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DEMO_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_MARKET_SEARCH_TERMS=weather,temperature,rain,snow,wind,hurricane
KALSHI_WEATHER_SERIES_TICKERS=KXHIGHNY,KXHIGHMIA,KXHIGHCHI,KXHIGHAUS,KXHIGHLAX,KXHIGHOKC

# Demo credentials: never reuse production credentials here.
KALSHI_DEMO_ACCESS_KEY=
KALSHI_DEMO_PRIVATE_KEY_PEM=

# Production credentials stay disabled unless live mode is explicitly enabled later.
KALSHI_PROD_ACCESS_KEY=
KALSHI_PROD_PRIVATE_KEY_PEM=
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_CONFIRMATION=true
KILL_SWITCH_ENABLED=true

# Risk defaults
MAX_STAKE_PER_TRADE_PAPER=0.50
MAX_DAILY_PAPER_LOSS=10
MAX_OPEN_PAPER_EXPOSURE=25
MAX_DAILY_TRADES=20
MAX_SPREAD=0.10
MIN_EDGE_PERCENTAGE_POINTS=8
STALE_MARKET_DATA_SECONDS=120
STALE_FORECAST_DATA_MINUTES=90

# Database
DATABASE_URL=postgresql://forecastedge:forecastedge@localhost:5432/forecastedge?schema=public
