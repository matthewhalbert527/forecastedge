generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppMode {
  watch
  paper
  demo
  live
}

enum Confidence {
  low
  medium
  high
}

enum WeatherVariable {
  high_temp
  low_temp
  rainfall
  snowfall
  wind_gust
  humidity
  hurricane
  unknown
}

enum SignalStatus {
  FIRED
  SKIPPED
}

enum OrderStatus {
  FILLED
  PARTIAL
  REJECTED
  CANCELLED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id                     String             @id @default(cuid())
  city                   String
  state                  String
  latitude               Float
  longitude              Float
  timezone               String
  stationId              String?
  stationName            String?
  settlementSource       String?
  accuweatherLocationKey String?
  pollingIntervalMinutes Int                @default(30)
  active                 Boolean            @default(true)
  createdAt              DateTime           @default(now())
  forecastSnapshots      ForecastSnapshot[]
}

model ForecastSnapshot {
  id            String          @id @default(cuid())
  provider      String
  locationId    String
  location      Location        @relation(fields: [locationId], references: [id])
  forecastRunAt DateTime
  targetDays    Json
  hourly        Json
  rawPayload    Json
  createdAt     DateTime        @default(now())
  deltas        ForecastDelta[]

  @@index([locationId, provider, forecastRunAt])
}

model ModelForecast {
  id                          String     @id
  locationId                  String
  city                        String
  state                       String
  stationId                   String?
  model                       String
  modelRunAt                  DateTime
  forecastValidAt             DateTime
  targetDate                  DateTime
  horizonHours                Int
  highTempF                   Float?
  lowTempF                    Float?
  precipitationAmountIn       Float?
  precipitationProbabilityPct Float?
  windGustMph                 Float?
  uncertaintyStdDevF          Float?
  freshnessMinutes            Float
  confidence                  Confidence
  rawPayload                  Json
  createdAt                   DateTime   @default(now())

  @@index([locationId, model, targetDate])
  @@index([stationId, targetDate])
}

model EnsembleForecast {
  id                 String          @id
  locationId         String
  city               String
  state              String
  stationId          String?
  targetDate         DateTime
  variable           WeatherVariable
  prediction         Float?
  uncertaintyStdDev  Float?
  confidence         Confidence
  contributingModels Json
  disagreement       Float?
  reason             String
  createdAt          DateTime        @default(now())

  @@index([locationId, targetDate, variable])
  @@index([stationId, targetDate])
}

model StationObservation {
  id           String   @id @default(cuid())
  stationId    String
  stationName  String
  observedAt   DateTime
  temperatureF Float?
  rawPayload   Json
  createdAt    DateTime @default(now())

  @@index([stationId, observedAt])
}

model ForecastDelta {
  id                String            @id @default(cuid())
  snapshotId        String?
  snapshot          ForecastSnapshot? @relation(fields: [snapshotId], references: [id])
  locationId        String
  variable          WeatherVariable
  targetDate        DateTime
  oldValue          Float
  newValue          Float
  absoluteChange    Float
  probabilityChange Float?
  timeHorizonHours  Int
  confidence        Confidence
  reason            String
  createdAt         DateTime          @default(now())
  signals           Signal[]

  @@index([locationId, variable, targetDate])
}

model KalshiMarket {
  ticker             String                      @id
  eventTicker        String
  title              String
  subtitle           String?
  closeTime          DateTime?
  settlementTime     DateTime?
  yesBid             Float?
  yesAsk             Float?
  noBid              Float?
  noAsk              Float?
  lastPrice          Float?
  volume             Float?
  openInterest       Float?
  liquidityScore     Float                       @default(0)
  rawPayload         Json
  updatedAt          DateTime                    @updatedAt
  mappings           MarketMapping[]
  signals            Signal[]
  quoteSnapshots     MarketQuoteSnapshot[]
  candidateSnapshots CandidateDecisionSnapshot[]
  candlesticks       KalshiMarketCandlestick[]
  trades             KalshiMarketTrade[]
}

model HistoricalKalshiMarket {
  ticker                 String    @id
  eventTicker            String
  title                  String
  subtitle               String?
  status                 String?
  result                 String?
  closeTime              DateTime?
  settlementTime         DateTime?
  settlementTs           DateTime?
  yesBid                 Float?
  yesAsk                 Float?
  noBid                  Float?
  noAsk                  Float?
  lastPrice              Float?
  volume                 Float?
  openInterest           Float?
  settlementValue        Float?
  rawPayload             Json
  fetchedAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([eventTicker])
  @@index([result, settlementTs])
}

model KalshiMarketCandlestick {
  id             String       @id
  marketTicker   String
  market         KalshiMarket @relation(fields: [marketTicker], references: [ticker])
  source         String
  periodInterval Int
  endPeriodTs    BigInt
  endPeriodAt    DateTime
  yesBidOpen     Float?
  yesBidLow      Float?
  yesBidHigh     Float?
  yesBidClose    Float?
  yesAskOpen     Float?
  yesAskLow      Float?
  yesAskHigh     Float?
  yesAskClose    Float?
  priceOpen      Float?
  priceLow       Float?
  priceHigh      Float?
  priceClose     Float?
  priceMean      Float?
  pricePrevious  Float?
  volume         Float?
  openInterest   Float?
  rawPayload     Json
  createdAt      DateTime     @default(now())

  @@unique([marketTicker, source, periodInterval, endPeriodTs])
  @@index([marketTicker, endPeriodAt])
  @@index([source, endPeriodAt])
}

model KalshiMarketTrade {
  id           String       @id
  marketTicker String
  market       KalshiMarket @relation(fields: [marketTicker], references: [ticker])
  source       String
  count        Float
  yesPrice     Float?
  noPrice      Float?
  takerSide    String?
  createdTime  DateTime
  rawPayload   Json
  createdAt    DateTime     @default(now())

  @@index([marketTicker, createdTime])
  @@index([source, createdTime])
}

model MarketQuoteSnapshot {
  id                 String       @id
  scanId             String?
  scanTrigger        String?
  scanCadenceMinutes Int?
  marketTicker       String
  market             KalshiMarket @relation(fields: [marketTicker], references: [ticker])
  eventTicker        String
  observedAt         DateTime
  source             String       @default("kalshi")
  yesBid             Float?
  yesAsk             Float?
  noBid              Float?
  noAsk              Float?
  lastPrice          Float?
  volume             Float?
  openInterest       Float?
  closeTime          DateTime?
  settlementTime     DateTime?
  rawPayload         Json
  createdAt          DateTime     @default(now())

  @@unique([marketTicker, observedAt])
  @@index([observedAt])
  @@index([scanId])
  @@index([scanTrigger, observedAt])
  @@index([marketTicker, observedAt])
}

model MarketMapping {
  id                String          @id @default(cuid())
  marketTicker      String
  market            KalshiMarket    @relation(fields: [marketTicker], references: [ticker])
  city              String?
  state             String?
  stationId         String?
  stationName       String?
  settlementSource  String?
  variable          WeatherVariable
  threshold         Float?
  thresholdOperator String
  targetDate        DateTime?
  confidence        Confidence
  accepted          Boolean
  reviewReason      String?
  rawPayload        Json
  createdAt         DateTime        @default(now())
}

model CandidateDecisionSnapshot {
  id                 String          @id
  scanId             String
  scanTrigger        String?
  scanCadenceMinutes Int?
  marketTicker       String
  market             KalshiMarket    @relation(fields: [marketTicker], references: [ticker])
  observedAt         DateTime
  title              String
  city               String?
  stationId          String?
  variable           WeatherVariable
  targetDate         DateTime?
  threshold          Float?
  thresholdOperator  String
  forecastValue      Float?
  entryPrice         Float?
  yesProbability     Float?
  rawYesProbability  Float?
  calibratedYesProbability Float?
  impliedProbability Float?
  edge               Float?
  grossEdge          Float?
  expectedSlippage   Float?
  spreadPenalty      Float?
  feePenalty         Float?
  netEdge            Float?
  uncertaintyPenalty Float?
  fillPenalty        Float?
  diversificationPenalty Float?
  qualityScore       Float?
  kellyFraction      Float?
  recommendedStake   Float?
  recommendedContracts Int?
  rankingReason      String?
  spread             Float?
  liquidityScore     Float
  status             String
  blockers           Json
  settlementResult   String?
  counterfactualPnl  Float?
  reason             String
  rawPayload         Json
  createdAt          DateTime        @default(now())

  @@index([scanId])
  @@index([marketTicker, observedAt])
  @@index([scanTrigger, observedAt])
  @@index([status, observedAt])
}

model Signal {
  id                 String         @id @default(cuid())
  marketTicker       String
  market             KalshiMarket   @relation(fields: [marketTicker], references: [ticker])
  forecastDeltaId    String?
  forecastDelta      ForecastDelta? @relation(fields: [forecastDeltaId], references: [id])
  side               String
  action             String
  contracts          Int
  limitPrice         Float
  maxCost            Float
  modelProbability   Float
  rawYesProbability  Float?
  calibratedYesProbability Float?
  impliedProbability Float
  edge               Float
  grossEdge          Float?
  expectedSlippage   Float?
  spreadPenalty      Float?
  feePenalty         Float?
  netEdge            Float?
  uncertaintyPenalty Float?
  fillPenalty        Float?
  diversificationPenalty Float?
  qualityScore       Float?
  kellyFraction      Float?
  recommendedStake   Float?
  recommendedContracts Int?
  rankingReason      String?
  confidence         Confidence
  explanation        String
  status             SignalStatus
  skipReason         String?
  createdAt          DateTime       @default(now())
  riskChecks         RiskCheck[]
  paperOrders        PaperOrder[]
}

model RiskCheck {
  id        String   @id @default(cuid())
  signalId  String
  signal    Signal   @relation(fields: [signalId], references: [id])
  allowed   Boolean
  reasons   Json
  createdAt DateTime @default(now())
}

model PaperOrder {
  id                    String                     @id
  signalId              String
  signal                Signal                     @relation(fields: [signalId], references: [id])
  timestamp             DateTime
  marketTicker          String
  side                  String
  action                String
  requestedContracts    Int
  limitPrice            Float
  simulatedAvgFillPrice Float?
  filledContracts       Int
  unfilledContracts     Int
  status                OrderStatus
  reason                String
  positionId            String?
  position              PaperPosition?             @relation(fields: [positionId], references: [id])
  trainingExample       PaperTradeTrainingExample?
}

model PaperTradeTrainingExample {
  id                 String           @id
  orderId            String           @unique
  order              PaperOrder       @relation(fields: [orderId], references: [id])
  signalId           String
  marketTicker       String
  side               String
  openedAt           DateTime
  requestedContracts Int
  filledContracts    Int
  limitPrice         Float
  entryPrice         Float?
  cost               Float
  modelProbability   Float?
  rawYesProbability  Float?
  calibratedYesProbability Float?
  impliedProbability Float?
  edge               Float?
  grossEdge          Float?
  expectedSlippage   Float?
  spreadPenalty      Float?
  feePenalty         Float?
  netEdge            Float?
  uncertaintyPenalty Float?
  fillPenalty        Float?
  diversificationPenalty Float?
  qualityScore       Float?
  kellyFraction      Float?
  recommendedStake   Float?
  recommendedContracts Int?
  forecastValue      Float?
  threshold          Float?
  thresholdOperator  String?
  targetDate         DateTime?
  variable           WeatherVariable?
  status             String
  settlementResult   String?
  settledAt          DateTime?
  payout             Float?
  pnl                Float?
  roi                Float?
  features           Json
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([marketTicker, openedAt])
  @@index([status, openedAt])
}

model PaperPosition {
  id            String       @id @default(cuid())
  marketTicker  String
  side          String
  contracts     Int
  avgEntryPrice Float
  markPrice     Float?
  realizedPnl   Float        @default(0)
  openedAt      DateTime     @default(now())
  closedAt      DateTime?
  settlementId  String?
  orders        PaperOrder[]

  @@unique([marketTicker, side])
}

model DemoOrder {
  id            String   @id @default(cuid())
  kalshiOrderId String?
  marketTicker  String
  request       Json
  response      Json?
  status        String
  createdAt     DateTime @default(now())
}

model LiveOrderIntent {
  id            String   @id @default(cuid())
  marketTicker  String
  request       Json
  riskSnapshot  Json
  uiConfirmed   Boolean  @default(false)
  approved      Boolean  @default(false)
  blockedReason Json?
  createdAt     DateTime @default(now())
}

model LiveOrder {
  id            String   @id @default(cuid())
  intentId      String   @unique
  kalshiOrderId String?
  status        String
  request       Json
  response      Json?
  createdAt     DateTime @default(now())
}

model Settlement {
  id           String   @id @default(cuid())
  marketTicker String   @unique
  result       String
  settledPrice Float
  source       String
  rawPayload   Json
  createdAt    DateTime @default(now())
}

model ScanReport {
  id              String    @id
  startedAt       DateTime
  completedAt     DateTime?
  status          String
  trigger         String
  providerResults Json
  counts          Json
  decisions       Json
  createdAt       DateTime  @default(now())

  @@index([startedAt])
}

model StrategyRun {
  id                String           @id @default(cuid())
  strategyVersionId String?
  strategyVersion   StrategyVersion? @relation(fields: [strategyVersionId], references: [id])
  mode              AppMode
  parameters        Json
  approvalStatus    String           @default("Draft")
  dataQualityScore  Float?
  warnings          Json?
  startedAt         DateTime         @default(now())
  completedAt       DateTime?
  summary           Json?

  @@index([approvalStatus, startedAt])
  @@index([strategyVersionId])
}

model StrategyVersion {
  id                    String        @id @default(cuid())
  strategyKey           String
  configHash            String
  config                Json
  codeVersion           String?
  dataSourceVersion     String
  backtestDate          DateTime?
  validationDate        DateTime?
  paperTradingStartDate DateTime?
  notes                 String?
  approvalStatus        String        @default("Draft")
  createdAt             DateTime      @default(now())
  runs                  StrategyRun[]

  @@index([strategyKey, createdAt])
  @@index([approvalStatus, createdAt])
}

model StrategyOptimizationRun {
  id             String    @id @default(cuid())
  status         String
  recommendation String
  searchSpace    Json
  champion       Json?
  bestCandidate  Json?
  challengers    Json
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([startedAt])
  @@index([status, startedAt])
}

model GptDecisionReview {
  id             String    @id @default(cuid())
  layer          String
  status         String
  model          String?
  promptVersion  String
  windowStart    DateTime
  windowEnd      DateTime
  inputSummary   Json
  output         Json?
  recommendation String?
  safeToApply    Boolean   @default(false)
  confidence     String?
  emailSent      Boolean   @default(false)
  emailMetadata  Json?
  appliedPatchId String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  @@index([layer, createdAt])
  @@index([status, createdAt])
}

model StrategyConfigPatch {
  id             String    @id @default(cuid())
  source         String
  reviewId       String?
  status         String
  reason         String
  previousConfig Json
  patch          Json
  appliedConfig  Json
  safety         Json
  appliedAt      DateTime?
  createdAt      DateTime  @default(now())

  @@index([status, appliedAt])
  @@index([reviewId])
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  type      String
  message   String
  metadata  Json
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model SystemEvent {
  id        String   @id @default(cuid())
  severity  String
  source    String
  message   String
  metadata  Json
  createdAt DateTime @default(now())
}
